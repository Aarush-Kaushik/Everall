{
  "name": "everall",
  "version": "1.2.4",
  "description": "Everall productivity app",
  "author": "Pawaaru Solutions",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.yourname.everall",
    "productName": "Everall",
    "icon": "./icon.ico",
    "asarUnpack": [
      "**/node_modules/youtube-dl-exec/**",
      "**/node_modules/ffmpeg-static/**"
    ],
    "forceCodeSigning": false,
    "win": {
      "target": "nsis",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "icon": "./icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Aarush-Kaushik",
        "repo": "Everall"
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.0.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "youtube-dl-exec": "^3.1.3"
  }
}